{
  "$schema": "./schemas/autopilot.schema.json",
  "runtime": "container",
  "copilotAuth": "pat",
  "gitProvider": "github",
  "gitAuth": "pat-shared",
  "model": "gpt-5.5",
  "git": {
    "name": "your-name",
    "email": "your-email@example.com"
  },
  "timeout": 180,
  "maxIterationsPerStep": 10,
  "build": "npm run build",
  "test": "npm test"
}
