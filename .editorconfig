root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{ps1,psd1,psm1}]
# Applies to both plugins/autopilot/scripts/** and scripts/skalary/**.
indent_size = 4

[*.json]
indent_size = 2

[*.sh]
end_of_line = lf
indent_size = 4

[.githooks/*]
end_of_line = lf
indent_size = 4

[*.md]
trim_trailing_whitespace = false
