{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jIRI-san/skillz/schemas/plugin.schema.json",
  "title": "Skillz Plugin Manifest",
  "description": "Manifest for a single plugin bundle under plugins/<name>/plugin.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "description", "author", "license", "tags", "dependencies", "files"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Globally unique plugin name."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
      "description": "Semantic version for the plugin."
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["src", "dest"],
        "properties": {
          "src": {
            "type": "string",
            "minLength": 1,
            "description": "Path under plugins/<name>/."
          },
          "dest": {
            "type": "string",
            "minLength": 1,
            "description": "Path under consuming repo .github/."
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["stable", "partial"],
      "description": "Optional plugin readiness status."
    },
    "evals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "status", "lastRun"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["none", "passing", "failing"]
        },
        "lastRun": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      },
      "description": "Reserved eval metadata (no runner contract yet)."
    }
  }
}
